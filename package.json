{
  "name": "google-docs-clone",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:server": "npm run dev --workspace=apps/sync-server",
    "start:web": "npm start --workspace=apps/web",
    "start:server": "npm start --workspace=apps/sync-server",
    "build:web": "npm run build --workspace=apps/web",
    "build:server": "npm run build --workspace=apps/sync-server",
    "dev:all": "npm run dev --workspaces --if-present"
  },
  "dependencies": {
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-collaboration": "^3.20.4",
    "@tiptap/extension-collaboration-cursor": "^3.0.0",
    "@tiptap/extension-horizontal-rule": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@tiptap/y-tiptap": "^3.0.2",
    "y-prosemirror": "^1.3.7"
  },
  "devDependencies": {
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5"
  }
}
